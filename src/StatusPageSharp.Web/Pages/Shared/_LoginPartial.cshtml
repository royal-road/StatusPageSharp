@using Microsoft.AspNetCore.Identity
@using StatusPageSharp.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <a class="nav-link-effect" asp-page="/Admin/Index">Admin</a>
    <a class="nav-link-effect" asp-area="Identity" asp-page="/Account/Manage/Index">@UserManager.GetUserName(User)</a>
    <form class="inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")">
        <button type="submit" class="nav-link-effect bg-transparent border-0 text-inherit font-inherit cursor-pointer">Logout</button>
    </form>
}
else
{
    <a class="nav-link-effect" asp-area="Identity" asp-page="/Account/Login">Login</a>
}
