@page
@model StatusPageSharp.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-baseline justify-between gap-4 mb-6">
        <h1 class="text-2xl font-display font-bold tracking-tight m-0">Admin Users</h1>
    </div>
    <form method="post" asp-page-handler="Create" class="grid grid-cols-2 gap-4 max-md:grid-cols-1">
        <div asp-validation-summary="ModelOnly" class="col-span-full text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="NewUser.Email">Email</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="NewUser.Email" />
            <span asp-validation-for="NewUser.Email" class="text-destructive text-xs"></span>
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="NewUser.DisplayName">Display Name</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="NewUser.DisplayName" />
            <span asp-validation-for="NewUser.DisplayName" class="text-destructive text-xs"></span>
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="NewUser.Password">Password</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="NewUser.Password" type="password" />
            <span asp-validation-for="NewUser.Password" class="text-destructive text-xs"></span>
        </div>
        <div class="flex flex-wrap gap-3 col-span-full">
            <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer" type="submit">Create User</button>
        </div>
    </form>
</section>

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full border-collapse">
            <thead>
                <tr>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Email</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Name</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Status</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Created</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var user in Model.Users)
            {
                <tr class="transition-colors hover:bg-white/[0.02]">
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@user.Email</td>
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@user.DisplayName</td>
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@(user.IsEnabled ? "Enabled" : "Disabled")</td>
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@user.CreatedUtc.ToLocalTime().ToString("g")</td>
                    <td class="px-3 py-3 border-b border-white/[0.03]">
                        <form method="post" asp-page-handler="Toggle" class="inline">
                            <input type="hidden" name="id" value="@user.Id" />
                            <input type="hidden" name="isEnabled" value="@(!user.IsEnabled)" />
                            <button class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-2.5 py-1 text-[0.78rem] font-semibold hover:bg-primary/15 transition-colors cursor-pointer" type="submit">@(user.IsEnabled ? "Disable" : "Enable")</button>
                        </form>
                    </td>
                </tr>
                <tr class="transition-colors hover:bg-white/[0.02]">
                    <td colspan="5" class="px-3 py-3 border-b border-white/[0.03]">
                        <form method="post" asp-page-handler="ResetPassword" class="flex items-end gap-3 max-md:flex-col max-md:items-stretch">
                            <input asp-for="PasswordReset.UserId" type="hidden" value="@user.Id" />
                            <div class="grid gap-1.5 flex-1">
                                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="PasswordReset.NewPassword">Reset Password for @user.Email</label>
                                <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="PasswordReset.NewPassword" />
                            </div>
                            <button class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-3.5 py-2.5 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors cursor-pointer whitespace-nowrap" type="submit">Reset Password</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
