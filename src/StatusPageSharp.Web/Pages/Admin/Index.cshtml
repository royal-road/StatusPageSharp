@page
@model StatusPageSharp.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
}

<section class="relative flex justify-between gap-8 rounded-2xl border border-border bg-gradient-to-br from-card to-secondary p-10 overflow-hidden isolate items-end max-md:flex-col max-md:p-7 max-md:items-start">
    <div class="absolute -top-[40%] -right-[15%] w-[55%] h-[180%] bg-[radial-gradient(ellipse,rgba(129,140,248,0.08),transparent_70%)] pointer-events-none"></div>
    <div class="relative z-10">
        <p class="font-mono text-xs font-medium tracking-[0.12em] uppercase text-primary">Admin</p>
        <h1 class="mt-1.5 mb-3 font-display text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold tracking-tight leading-[1.3] text-white">Operational control center</h1>
        <p class="max-w-xl text-muted-foreground leading-relaxed text-[0.95rem]">Manage services, incidents, maintenance windows, site settings, and admin users from the same application.</p>
    </div>
    <div class="relative z-10 grid justify-items-end gap-2 max-md:justify-items-start">
        <span class="status-pill large @StatusDisplayHelper.ToCssClass(Model.Dashboard.SiteStatus)">@StatusDisplayHelper.ToLabel(Model.Dashboard.SiteStatus)</span>
        <span class="font-mono text-[0.8rem] text-muted-foreground">@Model.Dashboard.OpenIncidentCount active incident(s)</span>
    </div>
</section>

<div class="grid gap-5 grid-cols-[repeat(auto-fit,minmax(220px,1fr))]">
    <article class="rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-white/10 hover:shadow-[0_0_40px_rgba(129,140,248,0.04)] hover:-translate-y-0.5">
        <h2 class="text-lg font-bold tracking-tight m-0 mb-3">Services</h2>
        <p class="text-muted-foreground text-sm mb-4">@Model.Dashboard.ServiceCount total</p>
        <a class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-3.5 py-2 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors"
           asp-page="/Admin/Services/Index">Manage Services</a>
    </article>
    <article class="rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-white/10 hover:shadow-[0_0_40px_rgba(129,140,248,0.04)] hover:-translate-y-0.5">
        <h2 class="text-lg font-bold tracking-tight m-0 mb-3">Groups</h2>
        <p class="text-muted-foreground text-sm mb-4">@Model.Dashboard.GroupCount total</p>
        <a class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-3.5 py-2 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors"
           asp-page="/Admin/ServiceGroups/Index">Manage Groups</a>
    </article>
    <article class="rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-white/10 hover:shadow-[0_0_40px_rgba(129,140,248,0.04)] hover:-translate-y-0.5">
        <h2 class="text-lg font-bold tracking-tight m-0 mb-3">Maintenance</h2>
        <p class="text-muted-foreground text-sm mb-4">@Model.Dashboard.ActiveMaintenanceCount active</p>
        <a class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-3.5 py-2 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors"
           asp-page="/Admin/Maintenance/Index">Manage Maintenance</a>
    </article>
    <article class="rounded-2xl border border-border bg-card p-6 shadow-sm transition-all duration-200 hover:border-white/10 hover:shadow-[0_0_40px_rgba(129,140,248,0.04)] hover:-translate-y-0.5">
        <h2 class="text-lg font-bold tracking-tight m-0 mb-3">Users</h2>
        <p class="text-muted-foreground text-sm mb-4">Create and disable admins</p>
        <a class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-3.5 py-2 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors"
           asp-page="/Admin/Users/Index">Manage Users</a>
    </article>
</div>

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex flex-wrap gap-3">
        <a class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm"
           asp-page="/Admin/Incidents/Index">Incidents</a>
        <a class="inline-flex items-center justify-center rounded-md bg-primary/10 text-primary border border-primary/10 px-4 py-2 text-[0.82rem] font-semibold hover:bg-primary/15 transition-colors"
           asp-page="/Admin/Settings/Index">Site Settings</a>
    </div>
</section>
