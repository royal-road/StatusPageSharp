@page
@model StatusPageSharp.Web.Pages.Admin.Maintenance.IndexModel
@{
    ViewData["Title"] = "Maintenance";
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-baseline justify-between gap-4 mb-6">
        <h1 class="text-2xl font-display font-bold tracking-tight m-0">Scheduled Maintenance</h1>
    </div>
    <form method="post" class="grid gap-4">
        <input asp-for="Input.TimeZoneOffsetMinutes" type="hidden" id="maintenance-timezone-offset" />
        <div asp-validation-summary="All" class="text-destructive text-sm" role="alert"></div>
        <div class="grid grid-cols-2 gap-4 max-md:grid-cols-1">
            <div class="grid gap-1.5">
                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.Title">Title</label>
                <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.Title" />
            </div>
            <div class="grid gap-1.5">
                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.Summary">Summary</label>
                <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.Summary" />
            </div>
            <div class="grid gap-1.5">
                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.StartsUtc">Starts At</label>
                <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.StartsUtc" type="datetime-local" />
            </div>
            <div class="grid gap-1.5">
                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.EndsUtc">Ends At</label>
                <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.EndsUtc" type="datetime-local" />
            </div>
            <div class="grid gap-1.5">
                <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase">Services</label>
                <select class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.ServiceIds" multiple size="8">
                    @foreach (var service in Model.Services)
                    {
                        <option value="@service.Id">@service.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="flex flex-wrap gap-3">
            <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer" type="submit">Schedule Maintenance</button>
        </div>
    </form>
</section>

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full border-collapse">
            <thead>
                <tr>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Title</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Window</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Services</th>
                    <th class="px-3 py-2.5 border-b border-white/10 text-left font-mono text-[0.7rem] font-medium tracking-[0.08em] uppercase text-muted-foreground/60">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.MaintenanceItems)
            {
                <tr class="transition-colors hover:bg-white/[0.02]">
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@item.Title</td>
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@item.StartsUtc.ToLocalTime().ToString("g") - @item.EndsUtc.ToLocalTime().ToString("g")</td>
                    <td class="px-3 py-3 border-b border-white/[0.03] text-[0.88rem]">@string.Join(", ", item.ServiceNames)</td>
                    <td class="px-3 py-3 border-b border-white/[0.03]">
                        <form method="post" asp-page-handler="Delete" class="inline" onsubmit="return confirm('Delete this scheduled maintenance window?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="inline-flex items-center justify-center rounded-md bg-destructive/10 text-destructive border border-destructive/10 px-2.5 py-1 text-[0.78rem] font-semibold hover:bg-destructive/15 transition-colors cursor-pointer" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        document.getElementById("maintenance-timezone-offset").value = String(new Date().getTimezoneOffset());
    </script>
}
