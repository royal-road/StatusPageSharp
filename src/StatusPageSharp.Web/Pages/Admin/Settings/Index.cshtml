@page
@model StatusPageSharp.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "Site Settings";
}

<section class="section-card">
    <div class="section-header"><h1>Site Settings</h1></div>
    <form method="post" class="form-grid two-up">
        <div class="field">
            <label asp-for="Input.SiteTitle">Site Title</label>
            <input asp-for="Input.SiteTitle" />
        </div>
        <div class="field">
            <label asp-for="Input.LogoUrl">Logo URL</label>
            <input asp-for="Input.LogoUrl" placeholder="https://example.com/logo.png" />
        </div>
        <div class="field">
            <label asp-for="Input.PublicRefreshIntervalSeconds">Refresh Interval (sec)</label>
            <input asp-for="Input.PublicRefreshIntervalSeconds" type="number" />
        </div>
        <div class="field">
            <label asp-for="Input.DefaultRawRetentionDays">Default Retention (days)</label>
            <input asp-for="Input.DefaultRawRetentionDays" type="number" />
        </div>
        <div class="button-row">
            <button class="button" type="submit">Save Settings</button>
        </div>
    </form>
</section>
