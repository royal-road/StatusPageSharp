@page
@model StatusPageSharp.Web.Pages.Admin.Settings.IndexModel
@{
    ViewData["Title"] = "Site Settings";
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-baseline justify-between gap-4 mb-6">
        <h1 class="text-2xl font-display font-bold tracking-tight m-0">Site Settings</h1>
    </div>
    <form method="post" class="grid grid-cols-2 gap-4 max-md:grid-cols-1">
        <div asp-validation-summary="All" class="col-span-full text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.SiteTitle">Site Title</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.SiteTitle" />
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.LogoUrl">Logo URL</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.LogoUrl" placeholder="https://example.com/logo.png" />
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.PublicRefreshIntervalSeconds">Refresh Interval (sec)</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.PublicRefreshIntervalSeconds" type="number" />
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.DefaultRawRetentionDays">Default Retention (days)</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.DefaultRawRetentionDays" type="number" />
        </div>
        <div class="flex flex-wrap gap-3 col-span-full">
            <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer" type="submit">Save Settings</button>
        </div>
    </form>
</section>
