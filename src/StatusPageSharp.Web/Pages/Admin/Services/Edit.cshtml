@page "{id:guid}"
@model StatusPageSharp.Web.Pages.Admin.Services.EditModel
@{
    ViewData["Title"] = "Edit Service";
}

<section class="section-card">
    <div class="section-header"><h1>Edit Service</h1></div>
    <form method="post" class="form-grid">

        <div class="form-section">
            <h3 class="form-section-title">Basic Information</h3>
            <div class="form-grid two-up">
                <div class="field">
                    <label asp-for="Input.Name">Name</label>
                    <input asp-for="Input.Name" />
                </div>
                <div class="field">
                    <label asp-for="Input.Slug">Slug</label>
                    <input asp-for="Input.Slug" />
                </div>
                <div class="field">
                    <label asp-for="Input.ServiceGroupId">Group</label>
                    <select asp-for="Input.ServiceGroupId">
                        @foreach (var group in Model.Groups)
                        {
                            <option value="@group.Id">@group.Name</option>
                        }
                    </select>
                </div>
                <div class="field">
                    <label asp-for="Input.IsEnabled">Status</label>
                    <select asp-for="Input.IsEnabled">
                        <option value="true">Enabled</option>
                        <option value="false">Disabled</option>
                    </select>
                </div>
                <div class="field field-wide">
                    <label asp-for="Input.Description">Description</label>
                    <input asp-for="Input.Description" />
                </div>
                <div class="field">
                    <label asp-for="Input.DisplayOrder">Display Order</label>
                    <input asp-for="Input.DisplayOrder" type="number" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Monitoring</h3>
            <div class="form-grid two-up">
                <div class="field">
                    <label asp-for="Input.MonitorType">Monitor Type</label>
                    <select asp-for="Input.MonitorType" asp-items="Html.GetEnumSelectList<StatusPageSharp.Domain.Enums.MonitorType>()"></select>
                </div>
                <div class="field">
                    <label asp-for="Input.CheckPeriodSeconds">Check Period (sec)</label>
                    <input asp-for="Input.CheckPeriodSeconds" type="number" />
                </div>
                <div class="field">
                    <label asp-for="Input.TimeoutSeconds">Timeout (sec)</label>
                    <input asp-for="Input.TimeoutSeconds" type="number" />
                </div>
                <div class="field">
                    <label asp-for="Input.RawRetentionDaysOverride">Retention Override (days)</label>
                    <input asp-for="Input.RawRetentionDaysOverride" type="number" />
                </div>
                <div class="field">
                    <label asp-for="Input.FailureThreshold">Failure Threshold</label>
                    <input asp-for="Input.FailureThreshold" type="number" />
                </div>
                <div class="field">
                    <label asp-for="Input.RecoveryThreshold">Recovery Threshold</label>
                    <input asp-for="Input.RecoveryThreshold" type="number" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Connection</h3>
            <div class="form-grid two-up">
                <div class="field">
                    <label asp-for="Input.Url">URL</label>
                    <input asp-for="Input.Url" />
                </div>
                <div class="field">
                    <label asp-for="Input.HttpMethod">HTTP Method</label>
                    <input asp-for="Input.HttpMethod" />
                </div>
                <div class="field">
                    <label asp-for="Input.Host">Host</label>
                    <input asp-for="Input.Host" />
                </div>
                <div class="field">
                    <label asp-for="Input.Port">Port</label>
                    <input asp-for="Input.Port" type="number" />
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Validation</h3>
            <div class="form-grid two-up">
                <div class="field">
                    <label asp-for="Input.ExpectedStatusCodes">Expected Status Codes</label>
                    <input asp-for="Input.ExpectedStatusCodes" />
                </div>
                <div class="field">
                    <label asp-for="Input.ExpectedResponseSubstring">Expected Response</label>
                    <input asp-for="Input.ExpectedResponseSubstring" />
                </div>
                <div class="field">
                    <label asp-for="Input.VerifyTlsCertificate">Verify TLS Certificate</label>
                    <select asp-for="Input.VerifyTlsCertificate">
                        <option value="true">Verify</option>
                        <option value="false">Skip verification</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h3 class="form-section-title">Advanced</h3>
            <div class="form-grid two-up">
                <div class="field">
                    <label asp-for="Input.RequestHeadersJson">Request Headers (JSON)</label>
                    <textarea asp-for="Input.RequestHeadersJson"></textarea>
                </div>
                <div class="field">
                    <label asp-for="Input.RequestBody">Request Body</label>
                    <textarea asp-for="Input.RequestBody"></textarea>
                </div>
            </div>
        </div>

        <div class="button-row">
            <button class="button" type="submit">Save Service</button>
            <a class="button-secondary" asp-page="/Admin/Services/Index">Back</a>
        </div>
    </form>
</section>
