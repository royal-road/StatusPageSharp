@page
@model StatusPageSharp.Web.Pages.IndexModel
@{
    ViewData["Title"] = "System Status";
}

<section class="hero-section flex items-center justify-between gap-8 max-md:flex-col max-md:items-start">
    <div>
        <h1 class="text-[clamp(2rem,4vw,3.25rem)] text-foreground mb-3">System Status</h1>
        <p class="max-w-lg text-muted-foreground leading-relaxed text-[0.95rem]">Live component health, active incidents, and scheduled maintenance — all in one place.</p>
    </div>
    <div class="status-chip @StatusDisplayHelper.ToCssClass(Model.SiteSummary.SiteStatus)">
        @StatusDisplayHelper.ToLabel(Model.SiteSummary.SiteStatus)
    </div>
</section>

@if (Model.SiteSummary.ActiveIncidents.Count > 0)
{
    <section class="obsidian-card p-6">
        <div class="flex items-baseline justify-between gap-4 mb-5">
            <h2 class="text-base font-semibold tracking-tight m-0">Active Incidents</h2>
            <a class="text-primary text-sm font-medium hover:opacity-80 transition-opacity" asp-page="/Incidents/Index">Incident History</a>
        </div>
        <div class="grid gap-3 grid-cols-[repeat(auto-fit,minmax(280px,1fr))]">
            @foreach (var incident in Model.SiteSummary.ActiveIncidents)
            {
                <a class="obsidian-card-elevated group p-5"
                   asp-page="/Incidents/Details" asp-route-id="@incident.Id">
                    <strong class="text-[0.9rem] font-semibold block mb-1.5 group-hover:text-primary transition-colors">@incident.Title</strong>
                    <p class="m-0 whitespace-pre-wrap text-muted-foreground text-[0.84rem] leading-relaxed">@incident.Summary</p>
                    <span class="block mt-2 text-muted-foreground/50 font-mono text-[0.72rem]">Started @incident.StartedUtc.ToLocalTime().ToString("g")</span>
                </a>
            }
        </div>
    </section>
}

@if (Model.SiteSummary.ActiveMaintenance.Count > 0)
{
    <section class="obsidian-card p-6">
        <div class="flex items-baseline justify-between gap-4 mb-5">
            <h2 class="text-base font-semibold tracking-tight m-0">Active Maintenance</h2>
            <a class="text-primary text-sm font-medium hover:opacity-80 transition-opacity" asp-page="/Maintenance/Index">All Maintenance</a>
        </div>
        <div class="grid gap-3 grid-cols-[repeat(auto-fit,minmax(280px,1fr))]">
            @foreach (var maintenance in Model.SiteSummary.ActiveMaintenance)
            {
                <article class="obsidian-card-elevated p-5">
                    <strong class="text-[0.9rem] font-semibold block mb-1.5">@maintenance.Title</strong>
                    <p class="m-0 text-muted-foreground text-[0.84rem] leading-relaxed">@maintenance.Summary</p>
                    <span class="block mt-2 text-muted-foreground/50 font-mono text-[0.72rem]">@maintenance.StartsUtc.ToLocalTime().ToString("g") – @maintenance.EndsUtc.ToLocalTime().ToString("g")</span>
                </article>
            }
        </div>
    </section>
}

<section class="obsidian-card p-6">
    <div class="flex items-baseline justify-between gap-4 mb-5">
        <h2 class="text-base font-semibold tracking-tight m-0">Components</h2>
        <span class="text-muted-foreground/60 text-sm font-mono">@Model.SiteSummary.Groups.Count group(s)</span>
    </div>
    @foreach (var group in Model.SiteSummary.Groups)
    {
        <div class="mt-5 first:mt-0 p-5 rounded-xl bg-secondary/40 border border-white/[0.03]">
            <div class="flex items-start justify-between gap-4 pb-4 border-b border-border mb-1 max-md:flex-col">
                <div>
                    <h3 class="m-0 font-semibold text-[0.95rem]">@group.Name</h3>
                    @if (!string.IsNullOrWhiteSpace(group.Description))
                    {
                        <p class="mt-1 mb-0 text-muted-foreground/70 text-[0.84rem]">@group.Description</p>
                    }
                </div>
                <span class="status-pill @StatusDisplayHelper.ToCssClass(group.Status)">@StatusDisplayHelper.ToLabel(group.Status)</span>
            </div>
            <div class="service-grid">
                @foreach (var service in group.Services)
                {
                    <a class="service-row"
                       asp-page="/Services/Details" asp-route-slug="@service.Slug">
                        <div class="min-w-0">
                            <strong class="text-[0.88rem] font-semibold block truncate">@service.Name</strong>
                            @if (!string.IsNullOrWhiteSpace(service.Description))
                            {
                                <span class="text-muted-foreground/60 text-[0.78rem] block mt-0.5">@service.Description</span>
                            }
                        </div>
                        <div class="max-md:hidden">
                            <partial name="~/Pages/Shared/_AvailabilityBars.cshtml"
                                     model="new AvailabilityBarSeriesModel(service.DailyStatuses, service.LastThirtyDayUptimePercentage, false, false)" />
                        </div>
                        <span class="status-pill @StatusDisplayHelper.ToCssClass(service.Status)">@StatusDisplayHelper.ToLabel(service.Status)</span>
                        <div class="flex items-center gap-3 font-mono text-[0.75rem] text-muted-foreground/60 tracking-tight max-md:hidden">
                            <span>@(service.LastLatencyMilliseconds?.ToString() ?? "--")<span class="text-muted-foreground/40">ms</span></span>
                            <span>@(service.LastThirtyDayUptimePercentage?.ToString("0.00") ?? "--")<span class="text-muted-foreground/40">%</span></span>
                        </div>
                    </a>
                }
            </div>
        </div>
    }
</section>
