@page "/services/{slug}"
@model StatusPageSharp.Web.Pages.Services.DetailsModel
@{
    ViewData["Title"] = Model.Service.Name;
}

<section class="hero-section flex items-end justify-between gap-8 max-md:flex-col max-md:items-start">
    <div>
        <span class="inline-block font-mono text-[0.72rem] font-medium tracking-[0.14em] uppercase text-primary/80 mb-2">@Model.Service.GroupName</span>
        <h1 class="text-[clamp(2rem,4vw,3.25rem)] text-foreground mb-3">@Model.Service.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Service.Description))
        {
            <p class="max-w-lg text-muted-foreground leading-relaxed text-[0.95rem]">@Model.Service.Description</p>
        }
    </div>
    <div class="grid justify-items-end gap-2.5 max-md:justify-items-start">
        <span class="status-pill large @StatusDisplayHelper.ToCssClass(Model.Service.Status)">@StatusDisplayHelper.ToLabel(Model.Service.Status)</span>
        <span class="font-mono text-[0.75rem] text-muted-foreground/60">Latest latency: @(Model.Service.LastLatencyMilliseconds?.ToString() ?? "--") ms</span>
    </div>
</section>

<div class="grid gap-6 grid-cols-[repeat(auto-fit,minmax(320px,1fr))]">
    <article class="obsidian-card-elevated p-6">
        <div class="flex items-baseline justify-between gap-4 mb-4">
            <h2 class="text-base font-semibold tracking-tight m-0">Availability</h2>
            <span class="text-muted-foreground/50 text-sm font-mono">48h</span>
        </div>
        <svg class="w-full min-h-60 overflow-visible" id="uptime-chart"></svg>
    </article>
    <article class="obsidian-card-elevated p-6">
        <div class="flex items-baseline justify-between gap-4 mb-4">
            <h2 class="text-base font-semibold tracking-tight m-0">Latency</h2>
            <span class="text-muted-foreground/50 text-sm font-mono">avg</span>
        </div>
        <svg class="w-full min-h-60 overflow-visible" id="latency-chart"></svg>
    </article>
</div>

<section class="obsidian-card p-6">
    <div class="flex items-baseline justify-between gap-4 mb-4">
        <h2 class="text-base font-semibold tracking-tight m-0">Monthly SLA</h2>
        <span class="text-muted-foreground/50 text-sm font-mono">calendar</span>
    </div>
    <svg class="w-full min-h-60 overflow-visible" id="sla-chart"></svg>
</section>

@section Scripts {
    <script>
        window.renderStatusChart("uptime-chart", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Service.UptimePoints)));
        window.renderStatusChart("latency-chart", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Service.LatencyPoints)));
        window.renderStatusChart("sla-chart", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Service.SlaPoints.Select(item => new { label = item.MonthLabel, value = item.UptimePercentage }))));
    </script>
}
