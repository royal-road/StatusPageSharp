@page "/services/{slug}"
@model StatusPageSharp.Web.Pages.Services.DetailsModel
@{
    ViewData["Title"] = Model.Service.Name;
    var healthyDays = Model.Service.DailyStatuses.Count(item => item.UptimePercentage >= 100m);
    var impactedDays = Model.Service.DailyStatuses.Count(item => item.UptimePercentage < 100m);
    var worstDay = Model.Service.DailyStatuses.OrderBy(item => item.UptimePercentage).FirstOrDefault();
    var worstDayDowntime = worstDay is null ? (decimal?)null : 100m - worstDay.UptimePercentage;
}

<section class="hero-section flex items-end justify-between gap-8 max-md:flex-col max-md:items-start">
    <div>
        <span class="inline-block font-mono text-[0.72rem] font-medium tracking-[0.14em] uppercase text-primary/80 mb-2">@Model.Service.GroupName</span>
        <h1 class="text-[clamp(2rem,4vw,3.25rem)] text-foreground mb-3">@Model.Service.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Service.Description))
        {
            <p class="max-w-lg text-muted-foreground leading-relaxed text-[0.95rem]">@Model.Service.Description</p>
        }
    </div>
    <div class="grid justify-items-end gap-2.5 max-md:justify-items-start">
        <span class="status-pill large @StatusDisplayHelper.ToCssClass(Model.Service.Status)">@StatusDisplayHelper.ToLabel(Model.Service.Status)</span>
        <span class="font-mono text-[0.75rem] text-muted-foreground/60">Latest latency: @(Model.Service.LastLatencyMilliseconds?.ToString() ?? "--") ms</span>
    </div>
</section>

<div class="grid items-start gap-6 grid-cols-[repeat(auto-fit,minmax(320px,1fr))]">
    <article class="obsidian-card-elevated min-h-60 p-6 flex flex-col">
        <div class="flex items-baseline justify-between gap-4 mb-4">
            <h2 class="text-base font-semibold tracking-tight m-0">Availability</h2>
            <span class="text-muted-foreground/50 text-sm font-mono">30d</span>
        </div>
        <div class="flex items-center justify-between gap-4 mb-4 max-md:flex-col max-md:items-start">
            <span class="text-muted-foreground/60 text-sm">Daily uptime over the last 30 days.</span>
            <span class="font-mono text-[0.8rem] text-muted-foreground/70">
                @(Model.Service.LastThirtyDayUptimePercentage?.ToString("0.00") ?? "--")%
            </span>
        </div>
        <div class="rounded-xl border border-white/[0.03] bg-secondary/40 p-4">
            <partial name="~/Pages/Shared/_AvailabilityBars.cshtml"
                     model="new AvailabilityBarSeriesModel(Model.Service.DailyStatuses, Model.Service.LastThirtyDayUptimePercentage, true, true)" />
        </div>
        <div class="grid grid-cols-3 gap-3 mt-auto pt-4 max-md:grid-cols-1">
            <div class="rounded-lg border border-white/[0.03] bg-secondary/30 p-3">
                <span class="block font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-foreground/45">Healthy Days</span>
                <strong class="block mt-1 text-[1.05rem] font-semibold text-foreground">@healthyDays</strong>
                <span class="block mt-1 text-[0.76rem] text-muted-foreground/60">days at 100% uptime</span>
            </div>
            <div class="rounded-lg border border-white/[0.03] bg-secondary/30 p-3">
                <span class="block font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-foreground/45">Impacted Days</span>
                <strong class="block mt-1 text-[1.05rem] font-semibold text-foreground">@impactedDays</strong>
                <span class="block mt-1 text-[0.76rem] text-muted-foreground/60">days with recorded downtime</span>
            </div>
            <div class="rounded-lg border border-white/[0.03] bg-secondary/30 p-3">
                <span class="block font-mono text-[0.68rem] uppercase tracking-[0.12em] text-muted-foreground/45">Worst Day</span>
                <strong class="block mt-1 text-[1.05rem] font-semibold text-foreground">@(worstDay?.Day.ToString("MMM d") ?? "--")</strong>
                <span class="block mt-1 text-[0.76rem] text-muted-foreground/60">@(worstDayDowntime is null ? "no recorded downtime" : $"{worstDayDowntime:0.00}% downtime")</span>
            </div>
        </div>
    </article>
    <article class="obsidian-card-elevated p-6">
        <div class="flex items-baseline justify-between gap-4 mb-4">
            <h2 class="text-base font-semibold tracking-tight m-0">Latency</h2>
            <span class="text-muted-foreground/50 text-sm font-mono">avg</span>
        </div>
        <svg class="w-full min-h-60 overflow-visible" id="latency-chart"></svg>
    </article>
</div>

<section class="obsidian-card p-6">
    <div class="flex items-baseline justify-between gap-4 mb-4">
        <h2 class="text-base font-semibold tracking-tight m-0">Last 12 Months SLA</h2>
        <span class="text-muted-foreground/50 text-sm font-mono">rolling</span>
    </div>
    <svg class="w-full min-h-60 overflow-visible" id="sla-chart"></svg>
</section>

@section Scripts {
    <script>
        window.renderStatusChart("latency-chart", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Service.LatencyPoints)), { valueSuffix: " ms", decimals: 0 });
        window.renderStatusChart("sla-chart", @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Service.SlaPoints.Select(item => new { label = item.MonthLabel, value = item.UptimePercentage }))), { valueSuffix: "%", decimals: 2 });
    </script>
}
