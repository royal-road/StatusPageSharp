@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access denied";
}

<section class="relative flex justify-between gap-8 rounded-2xl border border-border bg-gradient-to-br from-card to-secondary p-10 overflow-hidden isolate max-md:flex-col max-md:p-7">
    <div class="absolute -top-[40%] -right-[15%] w-[55%] h-[180%] bg-[radial-gradient(ellipse,rgba(248,113,113,0.06),transparent_70%)] pointer-events-none"></div>
    <div class="relative z-10">
        <p class="font-mono text-xs font-medium tracking-[0.12em] uppercase text-destructive">Access Denied</p>
        <h1 class="mt-1.5 mb-3 font-display text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold tracking-tight leading-[1.3] text-white">You do not have access to this resource</h1>
        <p class="max-w-xl text-muted-foreground leading-relaxed text-[0.95rem]">Please contact an administrator if you believe this is an error.</p>
    </div>
</section>
