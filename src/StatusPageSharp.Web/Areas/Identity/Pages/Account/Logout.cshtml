@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<section class="relative flex justify-between gap-8 rounded-2xl border border-border bg-gradient-to-br from-card to-secondary p-10 overflow-hidden isolate max-md:flex-col max-md:p-7">
    <div class="absolute -top-[40%] -right-[15%] w-[55%] h-[180%] bg-[radial-gradient(ellipse,rgba(129,140,248,0.08),transparent_70%)] pointer-events-none"></div>
    <div class="relative z-10">
        <p class="font-mono text-xs font-medium tracking-[0.12em] uppercase text-primary">Account</p>
        <h1 class="mt-1.5 mb-3 font-display text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold tracking-tight leading-[1.3] text-white">Logged out</h1>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="mt-4" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer">Click here to Logout</button>
            </form>
        }
        else
        {
            <p class="max-w-xl text-muted-foreground leading-relaxed text-[0.95rem]">You have successfully logged out of the application.</p>
        }
    </div>
</section>
