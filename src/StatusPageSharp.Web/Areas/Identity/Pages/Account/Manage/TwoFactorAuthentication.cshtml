@page
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Two-factor authentication";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-start justify-between gap-4 mb-5 max-md:flex-col max-md:items-start">
        <div>
            <h2 class="text-lg font-bold tracking-tight m-0">Two-factor authentication</h2>
            <p class="mt-2 mb-0 max-w-2xl text-sm text-muted-foreground">
                Add an authenticator app and recovery codes to protect your account with an extra sign-in challenge.
            </p>
        </div>
        <div class="rounded-lg border border-border bg-secondary/40 px-4 py-3">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Status</span>
            <strong class="mt-1 block text-base text-foreground">@(Model.Is2FaEnabled ? "Enabled" : "Disabled")</strong>
        </div>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="grid gap-4">
        <div class="grid gap-3 rounded-xl border border-border bg-secondary/30 p-4">
            <div class="flex items-center justify-between gap-4 max-md:flex-col max-md:items-start">
                <div>
                    <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Authenticator app</span>
                    <strong class="mt-1 block text-[0.95rem] text-foreground">@(Model.HasAuthenticator ? "Configured" : "Not configured")</strong>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm" asp-page="./EnableAuthenticator">
                        @(Model.HasAuthenticator ? "Manage authenticator" : "Set up authenticator")
                    </a>
                    @if (Model.HasAuthenticator)
                    {
                        <a class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./ResetAuthenticator">
                            Reset setup
                        </a>
                    }
                </div>
            </div>
        </div>

        <div class="grid gap-3 rounded-xl border border-border bg-secondary/30 p-4">
            <div class="flex items-center justify-between gap-4 max-md:flex-col max-md:items-start">
                <div>
                    <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Recovery codes</span>
                    <strong class="mt-1 block text-[0.95rem] text-foreground">@Model.RecoveryCodesLeft remaining</strong>
                </div>
                <a class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./GenerateRecoveryCodes">
                    @(Model.RecoveryCodesLeft == 0 ? "Generate codes" : "Regenerate codes")
                </a>
            </div>
        </div>

        @if (Model.Is2FaEnabled)
        {
            <div class="flex flex-wrap gap-3">
                <a class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./Disable2fa">
                    Disable 2FA
                </a>
                @if (Model.IsMachineRemembered)
                {
                    <form method="post" asp-page-handler="ForgetBrowser">
                        <button class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors cursor-pointer" type="submit">
                            Forget this browser
                        </button>
                    </form>
                }
            </div>
        }
    </div>
</section>
