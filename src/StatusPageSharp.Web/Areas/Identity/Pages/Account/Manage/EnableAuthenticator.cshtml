@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configure authenticator";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-start justify-between gap-4 mb-6 max-md:flex-col max-md:items-start">
        <div>
            <h2 class="text-lg font-bold tracking-tight m-0">Configure authenticator</h2>
            <p class="mt-2 mb-0 max-w-2xl text-sm text-muted-foreground">
                Add this account to an authenticator app, then verify the 6-digit code it gives you.
            </p>
        </div>
        <a class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./TwoFactorAuthentication">
            Back to 2FA
        </a>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <div class="grid gap-4 lg:grid-cols-2">
        <article class="rounded-xl border border-border bg-secondary/30 p-5">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Step 1</span>
            <h3 class="mt-2 text-[0.98rem] font-semibold text-foreground">Scan the QR code</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                Use a TOTP-compatible app such as Microsoft Authenticator, 1Password, or Google Authenticator. If scanning is unavailable, you can still enter the manual key shown alongside it.
            </p>
            <div class="mt-4 mx-auto flex aspect-square w-full max-w-xs items-center justify-center rounded-2xl bg-white p-4 shadow-sm">
                @Html.Raw(Model.QrCodeSvg)
            </div>
        </article>

        <article class="rounded-xl border border-border bg-secondary/30 p-5">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Manual key</span>
            <div class="mt-3 rounded-lg border border-border bg-background px-4 py-3 font-mono text-[0.9rem] tracking-[0.18em] text-foreground break-all">
                @Model.SharedKey
            </div>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
                If the direct link does not open your app, create a new TOTP entry manually and paste this key.
            </p>
        </article>
    </div>

    <form method="post" class="grid gap-5 max-w-md mt-6">
        <div asp-validation-summary="ModelOnly" class="text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.Code">Verification Code</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.Code" autocomplete="one-time-code" inputmode="numeric" placeholder="123456" />
            <span asp-validation-for="Input.Code" class="text-destructive text-xs"></span>
            <p class="m-0 text-xs text-muted-foreground">
                Spaces and dashes are ignored.
            </p>
        </div>
        <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2.5 text-[0.88rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer" type="submit">
            Verify and enable
        </button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
