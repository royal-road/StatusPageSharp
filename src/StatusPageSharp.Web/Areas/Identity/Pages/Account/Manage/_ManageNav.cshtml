@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<nav class="grid gap-0.5 rounded-xl border border-border bg-card p-3">
    <a class="block px-3 py-2 rounded-md text-[0.88rem] font-medium transition-colors @(ManageNavPages.IndexNavClass(ViewContext) == "active" ? "text-primary bg-primary/10 font-semibold" : "text-muted-foreground hover:text-foreground hover:bg-white/[0.04]")" id="profile" asp-page="./Index">Profile</a>
    <a class="block px-3 py-2 rounded-md text-[0.88rem] font-medium transition-colors @(ManageNavPages.EmailNavClass(ViewContext) == "active" ? "text-primary bg-primary/10 font-semibold" : "text-muted-foreground hover:text-foreground hover:bg-white/[0.04]")" id="email" asp-page="./Email">Email</a>
    <a class="block px-3 py-2 rounded-md text-[0.88rem] font-medium transition-colors @(ManageNavPages.ChangePasswordNavClass(ViewContext) == "active" ? "text-primary bg-primary/10 font-semibold" : "text-muted-foreground hover:text-foreground hover:bg-white/[0.04]")" id="change-password" asp-page="./ChangePassword">Password</a>
    <a class="block px-3 py-2 rounded-md text-[0.88rem] font-medium transition-colors @(ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext) == "active" ? "text-primary bg-primary/10 font-semibold" : "text-muted-foreground hover:text-foreground hover:bg-white/[0.04]")" id="two-factor-authentication" asp-page="./TwoFactorAuthentication">Two-factor auth</a>
</nav>
