@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery codes";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <div class="flex items-start justify-between gap-4 mb-6 max-md:flex-col max-md:items-start">
        <div>
            <h2 class="text-lg font-bold tracking-tight m-0">Recovery codes</h2>
            <p class="mt-2 mb-0 max-w-2xl text-sm text-muted-foreground">
                Store these codes somewhere offline. Each code can be used once if you lose access to your authenticator app.
            </p>
        </div>
        <a class="inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./TwoFactorAuthentication">
            Back to 2FA
        </a>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    @if (Model.RecoveryCodes.Length > 0)
    {
        <div class="rounded-xl border border-border bg-secondary/30 p-5">
            <div class="grid gap-3 sm:grid-cols-2">
                @foreach (var code in Model.RecoveryCodes)
                {
                    <div class="rounded-lg border border-border bg-background px-4 py-3 font-mono text-[0.88rem] tracking-[0.12em] text-foreground">
                        @code
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="rounded-xl border border-warn/20 bg-warn/8 p-5">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-warn">Important</span>
            <p class="mt-3 mb-0 text-sm leading-relaxed text-muted-foreground">
                Regenerating recovery codes invalidates the old set. Do this only after you have saved any codes you still need.
            </p>
        </div>
        <form method="post" class="mt-6">
            <button class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-[0.82rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer" type="submit">
                Generate new recovery codes
            </button>
        </form>
    }
</section>
