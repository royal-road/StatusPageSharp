@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout != null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Pages/Shared/_Layout.cshtml";
    }
}

<section class="relative flex justify-between gap-6 rounded-2xl border border-border bg-gradient-to-br from-card to-secondary p-8 overflow-hidden isolate max-md:flex-col max-md:p-6">
    <div class="absolute -top-[25%] -right-[10%] w-[40%] h-[140%] bg-[radial-gradient(ellipse,rgba(129,140,248,0.08),transparent_70%)] pointer-events-none"></div>
    <div class="relative z-10">
        <p class="font-mono text-xs font-medium tracking-[0.12em] uppercase text-primary">Account</p>
        <h1 class="mt-1.5 mb-3 font-display text-[clamp(1.6rem,3vw,2.35rem)] font-bold tracking-tight leading-[1.2] text-white">Manage your account</h1>
        <p class="max-w-xl text-muted-foreground leading-relaxed text-[0.95rem]">Update your profile, email, password, and sign-in security settings.</p>
    </div>
</section>

<div class="flex gap-6 max-md:flex-col">
    <div class="w-56 shrink-0 max-md:w-full">
        <partial name="_ManageNav" />
    </div>
    <div class="flex-1 min-w-0">
        @RenderBody()
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
