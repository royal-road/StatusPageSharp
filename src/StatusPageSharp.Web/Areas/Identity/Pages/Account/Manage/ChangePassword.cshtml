@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <h2 class="text-lg font-bold tracking-tight m-0 mb-4">@ViewData["Title"]</h2>
    <partial name="_StatusMessage" for="StatusMessage" />
    <form id="change-password-form" method="post" class="grid gap-5 max-w-md">
        <div asp-validation-summary="ModelOnly" class="text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.OldPassword">Current password</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.OldPassword" autocomplete="current-password" aria-required="true" placeholder="Current password" />
            <span asp-validation-for="Input.OldPassword" class="text-destructive text-xs"></span>
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.NewPassword">New password</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.NewPassword" autocomplete="new-password" aria-required="true" placeholder="New password" />
            <span asp-validation-for="Input.NewPassword" class="text-destructive text-xs"></span>
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.ConfirmPassword">Confirm password</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.ConfirmPassword" autocomplete="new-password" aria-required="true" placeholder="Confirm new password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-destructive text-xs"></span>
        </div>
        <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2.5 text-[0.88rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer">Update password</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
