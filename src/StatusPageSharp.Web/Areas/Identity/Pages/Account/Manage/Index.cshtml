@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<section class="rounded-2xl border border-border bg-card p-6 shadow-sm">
    <h2 class="text-lg font-bold tracking-tight m-0 mb-4">@ViewData["Title"]</h2>
    <partial name="_StatusMessage" for="StatusMessage" />
    <form id="profile-form" method="post" class="grid gap-5 max-w-md">
        <div asp-validation-summary="ModelOnly" class="text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Username">Username</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-muted text-muted-foreground text-[0.88rem] cursor-not-allowed" asp-for="Username" disabled />
        </div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.PhoneNumber">Phone number</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.PhoneNumber" placeholder="Enter your phone number" />
            <span asp-validation-for="Input.PhoneNumber" class="text-destructive text-xs"></span>
        </div>
        <button id="update-profile-button" type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2.5 text-[0.88rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer">Save</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
