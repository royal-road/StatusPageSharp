@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code sign-in";
    ViewData["Description"] = "Use a saved recovery code to finish signing in when your authenticator app is unavailable.";
}

<section class="relative flex justify-between gap-8 rounded-2xl border border-border bg-gradient-to-br from-card to-secondary p-10 overflow-hidden isolate max-md:flex-col max-md:p-7">
    <div class="absolute -top-[40%] -right-[15%] w-[55%] h-[180%] bg-[radial-gradient(ellipse,rgba(129,140,248,0.08),transparent_70%)] pointer-events-none"></div>
    <div class="relative z-10">
        <p class="font-mono text-xs font-medium tracking-[0.12em] uppercase text-primary">Account</p>
        <h1 class="mt-1.5 mb-3 font-display text-[clamp(1.75rem,3.5vw,2.75rem)] font-bold tracking-tight leading-[1.3] text-white">Use a recovery code</h1>
        <p class="max-w-xl text-muted-foreground leading-relaxed text-[0.95rem]">
            Recovery codes are single-use. Enter one exactly as it was saved when you set up two-factor authentication.
        </p>
    </div>
</section>

<section class="grid gap-4 lg:grid-cols-[minmax(0,26rem)_minmax(0,1fr)] items-start">
    <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="rounded-2xl border border-border bg-card p-6 shadow-sm grid gap-5">
        <div asp-validation-summary="ModelOnly" class="text-destructive text-sm" role="alert"></div>
        <div class="grid gap-1.5">
            <label class="text-[0.78rem] font-semibold text-muted-foreground tracking-wide uppercase" asp-for="Input.RecoveryCode">Recovery Code</label>
            <input class="w-full px-3 py-2.5 rounded-md border border-border bg-background text-foreground text-[0.88rem] placeholder:text-muted-foreground/50 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all" asp-for="Input.RecoveryCode" autocomplete="one-time-code" placeholder="xxxx-xxxx" />
            <span asp-validation-for="Input.RecoveryCode" class="text-destructive text-xs"></span>
        </div>

        <button type="submit" class="w-full inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-4 py-2.5 text-[0.88rem] font-semibold hover:opacity-90 transition-all hover:-translate-y-px shadow-sm cursor-pointer">
            Log in
        </button>
    </form>

    <aside class="rounded-2xl border border-border bg-card p-6 shadow-sm grid gap-4">
        <div class="rounded-xl border border-border bg-secondary/30 p-5">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Recovery codes</span>
            <h2 class="mt-2 text-[0.98rem] font-semibold text-foreground">Only use one when you need it</h2>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                Each recovery code can be used once. After signing in, generate a new set if you have used the last remaining codes.
            </p>
        </div>

        <div class="rounded-xl border border-border bg-secondary/30 p-5">
            <span class="block text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground">Back to app verification</span>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                If your authenticator device is available again, use the normal 6-digit code flow instead.
            </p>
            <a class="mt-4 inline-flex items-center justify-center rounded-md border border-border bg-background px-4 py-2 text-[0.82rem] font-semibold text-foreground hover:bg-secondary/50 transition-colors" asp-page="./LoginWith2fa" asp-route-returnUrl="@Model.ReturnUrl">
                Enter authenticator code
            </a>
        </div>
    </aside>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
